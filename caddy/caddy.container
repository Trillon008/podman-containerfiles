[Unit]
Description=Caddy
After=network-online.target

[Container]
Label=app=caddy
ContainerName=caddy
EnvironmentFile=caddy.env

UserNS=keep-id
AddCapability=CAP_NET_BIND_SERVICE

Volume=%h/containers/caddy/etc:/caddy/etc:z
Volume=%h/containers/caddy/var:/caddy/var:z

PublishPort=80:80/tcp
PublishPort=443:443/tcp

Image=localhost/localhost/caddy:2.10.2
Exec=run --config /caddy/etc/Caddyfile --adapter caddyfile

[Service]
TimeoutStartSec=300

[Install]
WantedBy=default.target
